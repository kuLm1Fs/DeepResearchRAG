# Environment
ENV=dev
DEBUG=true
LOG_LEVEL=DEBUG

# LLM Provider (deepseek / openai / qwen)
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=sk-your-deepseek-key
OPENAI_API_KEY=sk-your-openai-key
QWEN_API_KEY=sk-your-qwen-key

# Embedding (火山引擎)
VOLCENGINE_API_KEY=your-volcengine-key
VOLCENGINE_EMBEDDING_URL=https://open.volcengineapi.com/api/v1/embeddings

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# MinIO
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_news
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=rag_secure_password

# Observability
LLM_CACHE=true

# Prompt version (v1 / v2 / current)
PROMPT_VERSION=v1