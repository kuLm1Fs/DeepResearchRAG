# Environment
ENV=prod
DEBUG=false
LOG_LEVEL=WARNING

# LLM Provider (deepseek / openai / qwen)
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=

# Embedding (火山引擎)
VOLCENGINE_API_KEY=
VOLCENGINE_EMBEDDING_URL=https://open.volcengineapi.com/api/v1/embeddings

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# Observability
LLM_CACHE=false

# Prompt version (v1 / v2 / current)
PROMPT_VERSION=v1