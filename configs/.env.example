# =============================================================================
# RAG News Intelligence - 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值

# -----------------------------------------------------------------------------
# 环境配置
# -----------------------------------------------------------------------------
# 运行环境: dev / prod
ENV=dev
# 开启调试模式 (prod 环境强制关闭)
DEBUG=true
# 日志级别: DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# LLM 配置
# -----------------------------------------------------------------------------
# LLM 提供商: deepseek / openai / qwen
LLM_PROVIDER=deepseek
# 模型名称
LLM_MODEL=deepseek-v4-flash
# DeepSeek API Key
DEEPSEEK_API_KEY=
# OpenAI API Key
OPENAI_API_KEY=
# OpenAI Model
OPENAI_MODEL=gpt-4o-mini
# Qwen API Key
QWEN_API_KEY=
# Qwen Model
QWEN_MODEL=qwen-turbo

# -----------------------------------------------------------------------------
# Embedding 配置 (火山引擎)
# -----------------------------------------------------------------------------
VOLCENGINE_API_KEY=
VOLCENGINE_EMBEDDING_URL=https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal
VOLCENGINE_EMBEDDING_MODEL=doubao-embedding

# -----------------------------------------------------------------------------
# Milvus 配置
# -----------------------------------------------------------------------------
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# -----------------------------------------------------------------------------
# 观察与缓存配置
# -----------------------------------------------------------------------------
# 是否启用 LLM 响应缓存 (prod 环境强制关闭)
LLM_CACHE=true

# -----------------------------------------------------------------------------
# Prompt 版本配置
# -----------------------------------------------------------------------------
# Prompt 模板版本: v1 / v2 / ...
PROMPT_VERSION=v1

# -----------------------------------------------------------------------------
# LangSmith (可选，开发调试用)
# -----------------------------------------------------------------------------
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=rag-news-intelligence

# -----------------------------------------------------------------------------
# 路径配置 (通常不需要修改)
# -----------------------------------------------------------------------------
PROJECT_ROOT=/Users/poikoi/code/RAG